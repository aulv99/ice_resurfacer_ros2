<?xml version="1.0"?>
<robot name="ice_resurfacer" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="chassis_len" value="4.04"/>
  <xacro:property name="chassis_width" value="1.5"/>
  <xacro:property name="chassis_height" value="2.0"/>
  <xacro:property name="chassis_mass" value="3000.0"/>

  <xacro:property name="wheel_radius" value="0.4"/> <xacro:property name="wheel_width" value="0.4"/>
  <xacro:property name="wheel_mass" value="50.0"/>
  
  <xacro:property name="wheel_base_x" value="1.2"/> <xacro:property name="wheel_sep_y" value="0.8"/>  <xacro:property name="cond_width" value="2.13"/> <xacro:property name="cond_len" value="0.5"/>
  <xacro:property name="cond_height" value="0.5"/>

  <xacro:property name="ground_clearance" value="0.3"/>

  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0"
               iyy="${(m/12) * (w*w + d*d)}" iyz="0.0"
               izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0"
               iyy="${(m/12) * (3*r*r + h*h)}" iyz="0"
               izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_len} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.3" rpy="0 0 0"/> 
      <geometry>
        <box size="${chassis_len} ${chassis_width} ${chassis_height - 0.6}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}" w="${chassis_len}" h="${chassis_height}" d="${chassis_width}"/>
  </link>

  <xacro:macro name="rear_wheel" params="prefix reflect">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="${-wheel_base_x} ${reflect * wheel_sep_y} ${wheel_radius - (ground_clearance + chassis_height/2)}" rpy="${-pi/2} 0 0"/>      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:rear_wheel prefix="rear_left" reflect="1"/>
  <xacro:rear_wheel prefix="rear_right" reflect="-1"/>

  <xacro:macro name="front_steering" params="prefix reflect">
    <link name="${prefix}_steering_link">
      <inertial>
        <mass value="100.0"/>
        <inertia ixx="1.0" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="1.0"/>
      </inertial>
    </link>

    <joint name="${prefix}_steering_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_steering_link"/>
      <origin xyz="${wheel_base_x} ${reflect * wheel_sep_y} ${wheel_radius - (ground_clearance + chassis_height/2)}" rpy="0 0 0"/>      <axis xyz="0 0 1"/> <limit lower="-0.6" upper="0.6" effort="50000" velocity="1.0"/>
    </joint>

    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_steering_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 0 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/> </joint>
  </xacro:macro>

  <xacro:front_steering prefix="front_left" reflect="1"/>
  <xacro:front_steering prefix="front_right" reflect="-1"/>

  <link name="conditioner_link">
    <visual>
      <geometry>
        <box size="${cond_len} ${cond_width} ${cond_height}"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
    <xacro:box_inertia m="200" w="${cond_len}" h="${cond_height}" d="${cond_width}"/>
  </link>

  <joint name="conditioner_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="conditioner_link"/>
    <origin xyz="${-chassis_len/2 - 0.25} 0 ${-(chassis_height/2) + 0.1}" rpy="0 0 0"/>    <axis xyz="0 0 1"/> <limit lower="0.0" upper="0.5" effort="1000" velocity="0.5"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="1.5 0 0.8" rpy="0 0 0"/> 
  </joint>

  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1.0" r="0.05" h="0.1"/>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="${chassis_len/2 + 0.05} 0 ${-(chassis_height/2) + 0.2}" rpy="0 0 0"/>
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <joint name="front_left_steering_joint">
      <command_interface name="position">
        <param name="min">-0.6</param> <param name="max">0.6</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="front_right_steering_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="front_left_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="front_right_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="conditioner_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>0.2</mu1> <mu2>0.2</mu2>
  </gazebo>

  <gazebo reference="rear_left_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>2.0</mu1>
    <mu2>20.0</mu2>
    <fdir1>1 0 0</fdir1>
    <kp>10000000.0</kp> 
    <kd>1.0</kd>        
    <minDepth>0.005</minDepth> 
    <maxVel>0.1</maxVel>       
  </gazebo>

  <gazebo reference="rear_right_wheel">
    <material>Gazebo/DarkGrey</material>
    <mu1>2.0</mu1>
    <mu2>20.0</mu2>
    <fdir1>1 0 0</fdir1>
    <kp>10000000.0</kp> 
    <kd>1.0</kd>        
    <minDepth>0.005</minDepth> 
    <maxVel>0.1</maxVel>       
  </gazebo>

  <gazebo reference="front_left_wheel">
    <mu1>2.0</mu1>
    <mu2>20.0</mu2>
    <fdir1>1 0 0</fdir1> 
    <kp>10000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.005</minDepth>
    <maxVel>0.1</maxVel>      
  </gazebo>

  <gazebo reference="front_right_wheel">
    <mu1>2.0</mu1>
    <mu2>20.0</mu2>
    <fdir1>1 0 0</fdir1>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.005</minDepth>
    <maxVel>0.1</maxVel>       
  </gazebo>

  <gazebo reference="conditioner_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="base_link">
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find ice_resurfacer_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
    </sensor>
  </gazebo>

  <gazebo reference="laser_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <gz_frame_id>laser_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-1.5708</min_angle>
            <max_angle>1.5708</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.3</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>

</robot>